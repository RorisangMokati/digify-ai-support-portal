generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Ticket {
  id        String   @id @default(uuid())
  title     String
  message   String
  status    String   @default("open")
  priority  String   @default("medium")
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}